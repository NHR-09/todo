<?xml version="1.0" encoding="utf-8"?>
<!-- NHR Home Screen Widget — Milk + Dusty Grey -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="18dp">

    <!-- ROW 1: Branding + Streak -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_bolt"
            android:tint="#2A2A2A"
            android:contentDescription="app icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NHR"
            android:textColor="#2A2A2A"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.15"
            android:layout_marginStart="6dp" />

        <!-- Streak pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_streak_badge"
            android:paddingStart="8dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_flame"
                android:tint="#C4785B"
                android:contentDescription="streak" />

            <TextView
                android:id="@+id/widget_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#C4785B"
                android:textSize="12sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginStart="3dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ROW 2: Greeting + Level -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_hero_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECRUIT"
                android:textColor="#6B6B6B"
                android:textSize="9sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/widget_welcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good morning."
                android:textColor="#2A2A2A"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">
            <TextView
                android:id="@+id/widget_level"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="1"
                android:textColor="#2A2A2A"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:background="@drawable/widget_level_circle" />
        </FrameLayout>
    </LinearLayout>

    <!-- ROW 3: Compact Stats -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_stat_card_bg"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginEnd="4dp">
            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                android:src="@drawable/ic_check_circle" android:tint="#8FB996" android:contentDescription="tasks" />
            <TextView android:id="@+id/widget_tasks_value" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0" android:textColor="#2A2A2A"
                android:textSize="18sp" android:fontFamily="sans-serif-black" android:layout_marginTop="2dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tasks" android:textColor="#6B6B6B" android:textSize="8sp" android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_stat_card_bg"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginEnd="4dp">
            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                android:src="@drawable/ic_star" android:tint="#D4B896" android:contentDescription="xp" />
            <TextView android:id="@+id/widget_xp_value" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0" android:textColor="#2A2A2A"
                android:textSize="18sp" android:fontFamily="sans-serif-black" android:layout_marginTop="2dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="XP" android:textColor="#6B6B6B" android:textSize="8sp" android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_stat_card_bg"
            android:padding="10dp"
            android:gravity="center">
            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                android:src="@drawable/ic_play_circle" android:tint="#7B8FA1" android:contentDescription="lectures" />
            <TextView android:id="@+id/widget_lectures_value" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0" android:textColor="#2A2A2A"
                android:textSize="18sp" android:fontFamily="sans-serif-black" android:layout_marginTop="2dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lectures" android:textColor="#6B6B6B" android:textSize="8sp" android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

    <!-- ROW 4: XP Progress -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/widget_level_label" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Level 1" android:textColor="#2A2A2A"
                android:textSize="10sp" android:fontFamily="sans-serif-medium" />
            <TextView android:id="@+id/widget_xp_progress_label" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0 / 150 XP" android:textColor="#6B6B6B"
                android:textSize="10sp" android:fontFamily="sans-serif" />
        </LinearLayout>

        <ProgressBar android:id="@+id/widget_xp_progress" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="4dp"
            android:max="100" android:progress="0" android:progressDrawable="@drawable/widget_progress_bar"
            android:indeterminate="false" />
    </LinearLayout>

    <!-- ROW 5: Remaining counts -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:background="@drawable/widget_green_badge"
            android:padding="8dp" android:layout_marginEnd="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TASKS LEFT"
                android:textColor="#5A8C63" android:textSize="7sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.1" />
            <TextView android:id="@+id/widget_remaining_tasks" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0" android:textColor="#5A8C63"
                android:textSize="16sp" android:fontFamily="sans-serif-black" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:background="@drawable/widget_gold_badge"
            android:padding="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LECTURES LEFT"
                android:textColor="#5A7088" android:textSize="7sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.1" />
            <TextView android:id="@+id/widget_remaining_lectures" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0" android:textColor="#5A7088"
                android:textSize="16sp" android:fontFamily="sans-serif-black" />
        </LinearLayout>
    </LinearLayout>

    <!-- ROW 6: Pending Items List -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <!-- Item 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="2dp" android:paddingBottom="2dp">
            <ImageView android:id="@+id/widget_item_dot_1" android:layout_width="4dp" android:layout_height="4dp"
                android:src="@drawable/widget_dot" android:layout_marginEnd="8dp" android:contentDescription="dot" />
            <TextView android:id="@+id/widget_item_1" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#2A2A2A" android:textSize="11sp" android:fontFamily="sans-serif"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="2dp" android:paddingBottom="2dp">
            <ImageView android:id="@+id/widget_item_dot_2" android:layout_width="4dp" android:layout_height="4dp"
                android:src="@drawable/widget_dot" android:layout_marginEnd="8dp" android:contentDescription="dot" />
            <TextView android:id="@+id/widget_item_2" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#2A2A2A" android:textSize="11sp" android:fontFamily="sans-serif"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 3 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="2dp" android:paddingBottom="2dp">
            <ImageView android:id="@+id/widget_item_dot_3" android:layout_width="4dp" android:layout_height="4dp"
                android:src="@drawable/widget_dot" android:layout_marginEnd="8dp" android:contentDescription="dot" />
            <TextView android:id="@+id/widget_item_3" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#2A2A2A" android:textSize="11sp" android:fontFamily="sans-serif"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 4 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="2dp" android:paddingBottom="2dp">
            <ImageView android:id="@+id/widget_item_dot_4" android:layout_width="4dp" android:layout_height="4dp"
                android:src="@drawable/widget_dot" android:layout_marginEnd="8dp" android:contentDescription="dot" />
            <TextView android:id="@+id/widget_item_4" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#2A2A2A" android:textSize="11sp" android:fontFamily="sans-serif"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 5 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="2dp" android:paddingBottom="2dp">
            <ImageView android:id="@+id/widget_item_dot_5" android:layout_width="4dp" android:layout_height="4dp"
                android:src="@drawable/widget_dot" android:layout_marginEnd="8dp" android:contentDescription="dot" />
            <TextView android:id="@+id/widget_item_5" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#2A2A2A" android:textSize="11sp" android:fontFamily="sans-serif"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 6 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="2dp" android:paddingBottom="2dp">
            <ImageView android:id="@+id/widget_item_dot_6" android:layout_width="4dp" android:layout_height="4dp"
                android:src="@drawable/widget_dot" android:layout_marginEnd="8dp" android:contentDescription="dot" />
            <TextView android:id="@+id/widget_item_6" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#2A2A2A" android:textSize="11sp" android:fontFamily="sans-serif"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 7 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="2dp" android:paddingBottom="2dp">
            <ImageView android:id="@+id/widget_item_dot_7" android:layout_width="4dp" android:layout_height="4dp"
                android:src="@drawable/widget_dot" android:layout_marginEnd="8dp" android:contentDescription="dot" />
            <TextView android:id="@+id/widget_item_7" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#2A2A2A" android:textSize="11sp" android:fontFamily="sans-serif"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 8 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="2dp" android:paddingBottom="2dp">
            <ImageView android:id="@+id/widget_item_dot_8" android:layout_width="4dp" android:layout_height="4dp"
                android:src="@drawable/widget_dot" android:layout_marginEnd="8dp" android:contentDescription="dot" />
            <TextView android:id="@+id/widget_item_8" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#2A2A2A" android:textSize="11sp" android:fontFamily="sans-serif"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 9 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="2dp" android:paddingBottom="2dp">
            <ImageView android:id="@+id/widget_item_dot_9" android:layout_width="4dp" android:layout_height="4dp"
                android:src="@drawable/widget_dot" android:layout_marginEnd="8dp" android:contentDescription="dot" />
            <TextView android:id="@+id/widget_item_9" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#2A2A2A" android:textSize="11sp" android:fontFamily="sans-serif"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 10 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="2dp" android:paddingBottom="2dp">
            <ImageView android:id="@+id/widget_item_dot_10" android:layout_width="4dp" android:layout_height="4dp"
                android:src="@drawable/widget_dot" android:layout_marginEnd="8dp" android:contentDescription="dot" />
            <TextView android:id="@+id/widget_item_10" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#2A2A2A" android:textSize="11sp" android:fontFamily="sans-serif"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
